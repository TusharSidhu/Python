print("Welcome to FizzBuzz!")
def fizzbuzz(int):
    result = 0
    if int % 3 == 0 and int % 7 == 0:
        result = "FizzBuzz"
    elif int % 3 == 0:
        result = "Fizz"
    elif int % 7 == 0:
        result = "Buzz"
    elif "3" in str(int) and not(int % 3 == 0 and int % 7 == 0):
        result = "Almost Fizz"
    else:
        result = str(int)
    return result

int = int(input("Start number is 1, Enter the End number: "))
for i in range(1, int + 1):
    print(fizzbuzz(i))